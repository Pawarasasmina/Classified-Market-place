generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  DRAFT
  ACTIVE
  EXPIRED
  SOLD
  REMOVED
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  phone           String?
  displayName     String    @default("Marketplace User") @map("name")
  passwordHash    String?   @map("password")
  emailVerified   Boolean   @default(false) @map("isEmailVerified")
  phoneVerified   Boolean   @default(false) @map("isPhoneVerified")
  role            String    @default("USER")
  reputationScore Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  listings        Listing[]
}

model Category {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  description      String?
  schemaDefinition Json?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  listings         Listing[]
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("AED")
  location    String
  status      ListingStatus @default(DRAFT)
  attributes  Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sellerId    String
  categoryId  String
  seller      User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
}
