generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  REJECTED
  DELETED
  EXPIRED
  SOLD
  REMOVED
}

enum PhoneVerificationStatus {
  NOT_REQUESTED
  PENDING
  VERIFIED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  LISTING_CARD
  OFFER
  SYSTEM
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
  ACTIONED
}

enum BoostPlacement {
  TOP_LISTING
  HIGHLIGHTED_LISTING
  CATEGORY_PRIORITY
  HOMEPAGE_PROMOTION
  TIME_BASED_BOOST
  FEATURED
  SEARCH_TOP
  CATEGORY_TOP
}

enum BoostStatus {
  SCHEDULED
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionType {
  BOOST_PURCHASE
  LISTING_FEE
  WALLET_TOP_UP
  ADMIN_ADJUSTMENT
  ADMIN_CREDIT
  ADMIN_DEBIT
  LISTING_FEE_REFUND
  SELLER_LEVEL_UPGRADE
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum ListingPaymentMode {
  FREE
  PAID
}

enum MediaAssetType {
  IMAGE
  VIDEO
  FILE
}

enum NotificationType {
  SYSTEM
  LISTING
  MESSAGE
  OFFER
  BOOST
  TRANSACTION
  REPORT
  RATING
}

enum SellerPriorityTier {
  NONE
  AUTHORIZED
  VERIFIED
  VIP
}

enum SellerReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum SellerProfileStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum VerifiedSellerStatus {
  NOT_REQUESTED
  REQUESTED
  VERIFIED
  REJECTED
}

enum SellerDocumentSubmissionStatus {
  REQUESTED
  SUBMITTED
  APPROVED
  REJECTED
}

enum SellerPrivilegeTierCode {
  FREE
  PREMIUM
  VERIFIED
  VIP
}

enum ListingPriorityRuleTarget {
  BOOSTED_LISTING
  BOOST_PACKAGE
  PAID_LISTING
  CATEGORY_PRIORITY
  SELLER_RATING
  MANUAL_ADMIN_PRIORITY
  AUTHORIZED_SELLER
  VERIFIED_SELLER
  VIP_SELLER
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  googleId                 String?                   @unique
  phone                    String?
  displayName              String                    @default("Marketplace User") @map("name")
  passwordHash             String?                   @map("password")
  avatarUrl                String?
  bio                      String?
  location                 String?
  emailVerified            Boolean                   @default(false) @map("isEmailVerified")
  phoneVerified            Boolean                   @default(false) @map("isPhoneVerified")
  phoneVerificationStatus  PhoneVerificationStatus   @default(NOT_REQUESTED)
  phoneVerificationRequestedAt DateTime?
  phoneVerifiedAt          DateTime?
  failedLoginAttempts      Int                       @default(0)
  lastFailedLoginAt        DateTime?
  lockedUntil              DateTime?
  lastLoginAt              DateTime?
  termsAcceptedAt          DateTime?
  deactivatedAt            DateTime?
  role                     String                    @default("USER")
  sellerPriorityTier       SellerPriorityTier        @default(NONE)
  reputationScore          Int                       @default(0)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  listings                 Listing[]
  phoneOtps                PhoneOtpChallenge[]
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  authAuditLogs            AuthAuditLog[]
  blocksInitiated          UserBlock[]               @relation("Blocker")
  blocksReceived           UserBlock[]               @relation("BlockedUser")
  conversationParticipants ConversationParticipant[]
  conversationReports      ConversationReport[]
  messageReports           MessageReport[]
  hiddenMessages           MessageHidden[]
  sentMessages             Message[]                 @relation("SentMessages")
  readReceipts             MessageReadReceipt[]
  boostsPurchased          Boost[]
  transactions             Transaction[]
  walletAccount            WalletAccount?
  listingReports           ListingReport[]
  mediaAssets              MediaAsset[]              @relation("UploadedMediaAssets")
  notifications            Notification[]            @relation("RecipientNotifications")
  notificationsCreated     Notification[]            @relation("ActorNotifications")
  sellerRatingsReceived    SellerRating[]            @relation("SellerRatingsReceived")
  sellerRatingsGiven       SellerRating[]            @relation("SellerRatingsGiven")
  savedListings            SavedListing[]
  listingViews             ListingView[]
  auditLogs                AuditLog[]                @relation("ActorAuditLogs")
  reviewedListings         Listing[]                 @relation("ListingReviewedBy")
  sellerProfile            SellerProfile?
  reviewedSellerProfiles   SellerProfile[]           @relation("SellerProfileReviewedBy")
  submittedSellerDocuments SellerDocumentSubmission[] @relation("SellerDocumentSubmittedBy")
  reviewedSellerDocuments  SellerDocumentSubmission[] @relation("SellerDocumentReviewedBy")
  sellerBadgeAssignments   SellerBadgeAssignment[]   @relation("SellerBadgeOwner")
  assignedSellerBadges     SellerBadgeAssignment[]   @relation("SellerBadgeAssignedBy")
}

model Category {
  id                String                 @id @default(uuid())
  name              String
  slug              String                 @unique
  description       String?
  imageUrl          String?
  schemaDefinition  Json?
  listingExpiryDays Int                    @default(30)
  isActive          Boolean                @default(true)
  parentId          String?
  sortOrder         Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  parent            Category?              @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]             @relation("CategoryTree")
  listings          Listing[]
  boostPackages     BoostPackageCategory[]
  priorityRules     ListingPriorityRule[]
  privilegeQuotas   SellerPrivilegeCategoryQuota[]

  @@index([parentId])
}

model SellerProfile {
  id                    String               @id @default(uuid())
  userId                String               @unique
  status                SellerProfileStatus  @default(DRAFT)
  verifiedSellerStatus  VerifiedSellerStatus @default(NOT_REQUESTED)
  privilegeTierId       String?
  formDefinition        Json?
  formAnswers           Json?
  requestMetadata       Json?
  reviewMetadata        Json?
  reviewNotes           String?              @db.Text
  requestedAt           DateTime?
  submittedAt           DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  reviewedAt            DateTime?
  reviewedById          String?
  rejectionReason       String?              @db.Text
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy            User?                @relation("SellerProfileReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  privilegeTier         SellerPrivilegeTier? @relation(fields: [privilegeTierId], references: [id], onDelete: SetNull)
  documentRequests      SellerDocumentRequest[]
  documentSubmissions   SellerDocumentSubmission[]
  badgeAssignments      SellerBadgeAssignment[]

  @@index([status, createdAt])
  @@index([verifiedSellerStatus, createdAt])
  @@index([reviewedById, reviewedAt])
  @@index([privilegeTierId])
}

model SellerDocumentRequest {
  id              String                     @id @default(uuid())
  sellerProfileId String
  label           String
  slug            String
  description     String?
  isRequired      Boolean                    @default(true)
  formDefinition  Json?
  requestedAt     DateTime                   @default(now())
  dueAt           DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  sellerProfile   SellerProfile              @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  submissions     SellerDocumentSubmission[]

  @@unique([sellerProfileId, slug])
  @@index([requestedAt])
}

model SellerDocumentSubmission {
  id              String                         @id @default(uuid())
  sellerProfileId String
  requestId       String?
  submittedById   String
  status          SellerDocumentSubmissionStatus @default(SUBMITTED)
  answers         Json?
  files           Json?
  reviewMetadata  Json?
  reviewNotes     String?                        @db.Text
  rejectionReason String?                        @db.Text
  submittedAt     DateTime                       @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  sellerProfile   SellerProfile                  @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  request         SellerDocumentRequest?         @relation(fields: [requestId], references: [id], onDelete: SetNull)
  submittedBy     User                           @relation("SellerDocumentSubmittedBy", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy      User?                          @relation("SellerDocumentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([sellerProfileId, submittedAt])
  @@index([requestId, submittedAt])
  @@index([status, submittedAt])
  @@index([reviewedById, reviewedAt])
}

model SellerPrivilegeTier {
  id                     String                        @id @default(uuid())
  code                   SellerPrivilegeTierCode       @unique
  name                   String
  slug                   String                        @unique
  description            String?
  monthlyFreeListingLimit Int                          @default(0)
  activeListingLimit     Int?
  pendingListingLimit    Int?
  paidListingFee         Decimal                       @default(0) @db.Decimal(12, 2)
  sellerLevelUpgradeFee  Decimal                       @default(0) @db.Decimal(12, 2)
  currency               String                        @default("AED")
  isActive               Boolean                       @default(true)
  sortOrder              Int                           @default(0)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  sellerProfiles         SellerProfile[]
  categoryQuotas         SellerPrivilegeCategoryQuota[]

  @@index([isActive, sortOrder])
}

model SellerPrivilegeCategoryQuota {
  id                    String               @id @default(uuid())
  sellerPrivilegeTierId String
  categoryId            String
  monthlyFreeListingLimit Int?
  activeListingLimit    Int?
  pendingListingLimit   Int?
  paidListingFee        Decimal?             @db.Decimal(12, 2)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  sellerPrivilegeTier   SellerPrivilegeTier  @relation(fields: [sellerPrivilegeTierId], references: [id], onDelete: Cascade)
  category              Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([sellerPrivilegeTierId, categoryId])
  @@index([categoryId])
}

model SellerBadgeType {
  id              String                  @id @default(uuid())
  label           String
  slug            String                  @unique
  description     String?
  icon            String?
  style           Json?
  backgroundColor String?
  textColor       String?
  isActive        Boolean                 @default(true)
  isHidden        Boolean                 @default(false)
  sortOrder       Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  assignments     SellerBadgeAssignment[]

  @@index([isActive, isHidden, sortOrder])
}

model SellerBadgeAssignment {
  id              String           @id @default(uuid())
  userId          String
  sellerProfileId String?
  badgeTypeId     String
  assignedById    String?
  metadata        Json?
  assignedAt      DateTime         @default(now())
  expiresAt       DateTime?
  user            User             @relation("SellerBadgeOwner", fields: [userId], references: [id], onDelete: Cascade)
  sellerProfile   SellerProfile?   @relation(fields: [sellerProfileId], references: [id], onDelete: SetNull)
  badgeType       SellerBadgeType  @relation(fields: [badgeTypeId], references: [id], onDelete: Cascade)
  assignedBy      User?            @relation("SellerBadgeAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, badgeTypeId])
  @@index([badgeTypeId, assignedAt])
  @@index([sellerProfileId, assignedAt])
}

model Listing {
  id                     String             @id @default(uuid())
  clientDraftKey         String?
  title                  String
  description            String
  price                  Decimal            @db.Decimal(12, 2)
  currency               String             @default("AED")
  location               String
  status                 ListingStatus      @default(DRAFT)
  listingPaymentMode     ListingPaymentMode @default(FREE)
  attributes             Json?
  submittedAt            DateTime?
  approvedAt             DateTime?
  rejectedAt             DateTime?
  reviewedAt             DateTime?
  reviewedById           String?
  rejectionReason        String?            @db.Text
  publishedAt            DateTime?
  expiresAt              DateTime?
  soldAt                 DateTime?
  removedAt              DateTime?
  boostedUntil           DateTime?
  boostPriority          Int?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  sellerId               String
  categoryId             String
  paidPriorityEnabled    Boolean            @default(false)
  adminPriorityPromoted  Boolean            @default(false)
  adminPriorityPinned    Boolean            @default(false)
  adminPriorityScore     Int?
  adminPriorityStartsAt  DateTime?
  adminPriorityExpiresAt DateTime?
  seller                 User               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category               Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  reviewedBy             User?              @relation("ListingReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  images                 ListingImage[]
  conversations          Conversation[]
  sharedMessages         Message[]          @relation("SharedListingMessages")
  boosts                 Boost[]
  transactions           Transaction[]
  reports                ListingReport[]
  mediaAssets            MediaAsset[]
  notifications          Notification[]
  sellerRatings          SellerRating[]
  savedBy                SavedListing[]
  views                  ListingView[]

  @@unique([sellerId, clientDraftKey])
  @@index([sellerId])
  @@index([sellerId, listingPaymentMode, status])
  @@index([categoryId])
  @@index([status])
  @@index([expiresAt])
  @@index([reviewedById, reviewedAt])
  @@index([status, boostedUntil, boostPriority])
  @@index([status, paidPriorityEnabled])
  @@index([status, adminPriorityPromoted, adminPriorityStartsAt, adminPriorityExpiresAt])
  @@index([status, adminPriorityPinned, adminPriorityStartsAt, adminPriorityExpiresAt])
  @@index([status, adminPriorityScore, adminPriorityStartsAt, adminPriorityExpiresAt])
}

model MarketplaceSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedListing {
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([listingId, createdAt])
  @@index([userId, createdAt])
}

model ListingView {
  id        String   @id @default(uuid())
  listingId String
  viewerId  String?
  boostId   String?
  source    String?
  viewedAt  DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewer    User?    @relation(fields: [viewerId], references: [id], onDelete: SetNull)
  boost     Boost?   @relation(fields: [boostId], references: [id], onDelete: SetNull)

  @@index([listingId, viewedAt])
  @@index([viewerId, viewedAt])
  @@index([boostId, viewedAt])
}

model ListingImage {
  id           String      @id @default(uuid())
  listingId    String
  mediaAssetId String?
  url          String
  altText      String?
  sortOrder    Int         @default(0)
  isPrimary    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  listing      Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([listingId, sortOrder])
  @@index([mediaAssetId])
}

model Conversation {
  id            String                    @id @default(uuid())
  listingId     String?
  listing       Listing?                  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  participants  ConversationParticipant[]
  messages      Message[]
  reports       ConversationReport[]
  notifications Notification[]

  @@index([listingId])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  unreadCount    Int          @default(0)
  lastReadAt     DateTime?
  mutedAt        DateTime?
  archivedAt     DateTime?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id                String               @id @default(uuid())
  conversationId    String
  senderId          String
  type              MessageType          @default(TEXT)
  legacyBody        String?              @map("body") @db.Text
  encryptedBody     String?              @db.Text
  encryptedPayload  String?              @db.Text
  encryptionIv      String               @default("") @db.Text
  encryptionAuthTag String               @default("") @db.Text
  listingId         String?
  offerAmount       Decimal?             @db.Decimal(12, 2)
  offerCurrency     String?
  offerStatus       OfferStatus?
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  conversation      Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User                 @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  listing           Listing?             @relation("SharedListingMessages", fields: [listingId], references: [id], onDelete: SetNull)
  hiddenFor         MessageHidden[]
  readReceipts      MessageReadReceipt[]
  reports           MessageReport[]
  mediaAssets       MediaAsset[]
  notifications     Notification[]

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model MessageHidden {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  hiddenAt  DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, hiddenAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  deviceName String?
  userAgent String?
  ipAddress String?
  rememberMe Boolean   @default(false)
  expiresAt DateTime
  revokedAt DateTime?
  revokedReason String?
  lastUsedAt DateTime  @default(now())
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  event     String
  email     String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([email, createdAt])
}

model UserBlock {
  id            String   @id @default(uuid())
  blockerId     String
  blockedUserId String
  reason        String?
  createdAt     DateTime @default(now())
  blocker       User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockedUserId])
}

model ConversationReport {
  id             String       @id @default(uuid())
  conversationId String
  reporterId     String
  reason         String
  details        String?
  status         ReportStatus @default(OPEN)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reporter       User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
}

model MessageReport {
  id         String       @id @default(uuid())
  messageId  String
  reporterId String
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  message    Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
}

model Boost {
  id            String         @id @default(uuid())
  listingId     String
  purchaserId   String
  transactionId String?
  packageId     String?
  placement     BoostPlacement @default(HIGHLIGHTED_LISTING)
  status        BoostStatus    @default(SCHEDULED)
  startsAt      DateTime
  endsAt        DateTime
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  listing       Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  purchaser     User           @relation(fields: [purchaserId], references: [id], onDelete: Cascade)
  transaction   Transaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  package       BoostPackage?  @relation(fields: [packageId], references: [id], onDelete: SetNull)
  views         ListingView[]

  @@index([listingId, status])
  @@index([packageId])
  @@index([purchaserId, createdAt])
  @@index([status, startsAt, endsAt])
  @@index([transactionId])
}

model BoostPackage {
  id            String                 @id @default(uuid())
  slug          String                 @unique
  name          String
  description   String?
  placement     BoostPlacement
  price         Decimal                @db.Decimal(12, 2)
  currency      String                 @default("AED")
  durationDays  Int
  isActive      Boolean                @default(true)
  sortOrder     Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  boosts        Boost[]
  categories    BoostPackageCategory[]
  priorityRules ListingPriorityRule[]

  @@index([isActive, sortOrder])
  @@index([placement, isActive])
}

model BoostPackageCategory {
  boostPackageId String
  categoryId     String
  createdAt      DateTime     @default(now())
  boostPackage   BoostPackage @relation(fields: [boostPackageId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([boostPackageId, categoryId])
  @@index([categoryId])
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  listingId     String?
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  amount        Decimal           @db.Decimal(12, 2)
  currency      String            @default("AED")
  provider      String?
  providerRef   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing       Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  boosts        Boost[]
  walletLedgers WalletLedger[]
  notifications Notification[]

  @@unique([provider, providerRef])
  @@index([userId, createdAt])
  @@index([listingId])
  @@index([status, createdAt])
  @@index([type, createdAt])
}

model ListingPriorityRule {
  id             String                    @id @default(uuid())
  name           String
  target         ListingPriorityRuleTarget
  boostPackageId String?
  boostPackage   BoostPackage?             @relation(fields: [boostPackageId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       Category?                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  weight         Int                       @default(0)
  isActive       Boolean                   @default(true)
  sortOrder      Int                       @default(0)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([isActive, sortOrder])
  @@index([target, isActive])
  @@index([boostPackageId])
  @@index([categoryId])
}

model WalletAccount {
  id        String         @id @default(uuid())
  userId    String         @unique
  balance   Decimal        @default(0) @db.Decimal(12, 2)
  currency  String         @default("AED")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger    WalletLedger[]

  @@index([currency])
}

model WalletLedger {
  id            String        @id @default(uuid())
  walletId      String
  transactionId String?
  type          String
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("AED")
  balanceAfter  Decimal       @db.Decimal(12, 2)
  metadata      Json?
  createdAt     DateTime      @default(now())
  wallet        WalletAccount @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction   Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([transactionId])
  @@index([type, createdAt])
}

model ListingReport {
  id         String       @id @default(uuid())
  listingId  String
  reporterId String
  reason     String
  details    String?
  adminNotes String?
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
}

model SellerRating {
  id                   String             @id @default(uuid())
  sellerId             String
  raterId              String
  listingId            String
  stars                Int
  review               String?            @db.Text
  reviewStatus         SellerReviewStatus @default(PENDING)
  reviewModerationNote String?            @db.Text
  reviewModeratedAt    DateTime?
  reviewModeratedById  String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  seller               User               @relation("SellerRatingsReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  rater                User               @relation("SellerRatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  listing              Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([raterId, listingId])
  @@index([sellerId, createdAt])
  @@index([listingId, createdAt])
}

model MediaAsset {
  id            String         @id @default(uuid())
  uploadedById  String?
  listingId     String?
  messageId     String?
  type          MediaAssetType @default(IMAGE)
  url           String
  storageKey    String?
  mimeType      String?
  byteSize      Int?
  width         Int?
  height        Int?
  altText       String?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  uploadedBy    User?          @relation("UploadedMediaAssets", fields: [uploadedById], references: [id], onDelete: SetNull)
  listing       Listing?       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  message       Message?       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  listingImages ListingImage[]

  @@index([uploadedById, createdAt])
  @@index([listingId, createdAt])
  @@index([messageId, createdAt])
  @@index([type, createdAt])
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  actorId        String?
  listingId      String?
  conversationId String?
  messageId      String?
  transactionId  String?
  type           NotificationType
  title          String
  body           String?
  metadata       Json?
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation("RecipientNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor          User?            @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  listing        Listing?         @relation(fields: [listingId], references: [id], onDelete: SetNull)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message?         @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transaction    Transaction?     @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([actorId, createdAt])
  @@index([listingId, createdAt])
  @@index([conversationId, createdAt])
  @@index([messageId, createdAt])
  @@index([transactionId, createdAt])
  @@index([type, createdAt])
}

model AuditLog {
  id              String   @id @default(uuid())
  actorId         String?
  action          String
  entityType      String?
  entityId        String?
  method          String
  path            String
  statusCode      Int?
  success         Boolean  @default(true)
  ipAddress       String?
  userAgent       String?
  requestBody     Json?
  requestParams   Json?
  requestQuery    Json?
  responseSummary Json?
  errorMessage    String?
  durationMs      Int?
  createdAt       DateTime @default(now())
  actor           User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([success, createdAt])
}

model PhoneOtpChallenge {
  id         String    @id @default(uuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([phone, createdAt])
}
